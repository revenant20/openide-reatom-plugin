{
  // Использовать TypeScript из монорепозитория (<repo>/node_modules/typescript),
  // а не встроенный в VS Code. Обязательно: tsserver ищет плагины из tsconfig
  // в node_modules рядом со своей установкой. Встроенный TS лежит внутри
  // VS Code.app и node_modules проекта не видит — плагин не грузится.
  // Плюс нужно один раз выбрать «Use Workspace Version» — см. README.
  "typescript.tsdk": "../../node_modules/typescript/lib",

  // Reatom-подсказки едут на инфраструктуре штатных TS inlay hints — нужна
  // хотя бы одна включённая настройка. enumMemberValues открывает гейт и не
  // добавляет своего шума (в playground нет enum'ов).
  "editor.inlayHints.enabled": "on",
  "typescript.inlayHints.enumMemberValues.enabled": true
}
