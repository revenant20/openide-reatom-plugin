{
  "name": "@openide/reatom-ts-plugin",
  "version": "0.0.0",
  "description": "Анализатор реактивного графа Reatom v1001 — строит JSON-модель связей для reatom-ide-plugin",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:analyzer",
    "build:analyzer": "esbuild src/analyzer/cli.ts --bundle --platform=node --target=node18 --minify --legal-comments=none --outfile=dist/analyzer/reatom-analyzer.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "esbuild": "^0.25.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
