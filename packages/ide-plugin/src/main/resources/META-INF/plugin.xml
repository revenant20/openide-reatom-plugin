<idea-plugin>
    <id>ru.openide.reatom</id>
    <name>Reatom Support</name>
    <vendor url="https://openide.ru">OpenIDE</vendor>

    <description><![CDATA[
        Native support for the Reatom v1001 reactive state manager.
        Code Lens and gutter icons summarising atoms' reactive links —
        built from the static reactive graph produced by the
        @openide/reatom-ts-plugin analyzer.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.codeVisionProvider
                implementation="ru.openide.reatom.codevision.ReatomCodeVisionProvider"/>
        <postStartupActivity
                implementation="ru.openide.reatom.ReatomStartupActivity"/>
    </extensions>

    <projectListeners>
        <listener class="ru.openide.reatom.gutter.ReatomFileEditorListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>
</idea-plugin>
